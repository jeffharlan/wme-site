---
import { db } from '../lib/db';
import { events } from '../lib/schema';
import { eq, desc } from 'drizzle-orm';

let event: any = null;
try {
  const activeEvents = await db.select().from(events).where(eq(events.isActive, true)).orderBy(desc(events.createdAt)).limit(1);
  event = activeEvents[0] || null;
} catch {
  // DB not available — show fallback
}

const formattedDate = event?.eventDate
  ? new Date(event.eventDate + 'T00:00:00').toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })
  : null;
---

<section id="events" class="py-28 md:py-36 relative">
  <div class="section-number" aria-hidden="true">06</div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="section-narrow relative z-10">
    {event ? (
      <div class="grid lg:grid-cols-2 gap-12 items-center">
        <!-- Left -->
        <div class="reveal-left">
          <div class="label-text mb-5">Upcoming Event</div>
          <h2 class="heading-section text-white mb-6" data-text-reveal>
            {event.title}
          </h2>
          {event.description && (
            <p class="body-md mb-8">{event.description}</p>
          )}

          <div class="space-y-3 mb-8">
            {[
              ...(formattedDate ? [{ icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`, label: 'Date', value: formattedDate }] : []),
              ...(event.location ? [{ icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`, label: 'Location', value: event.location }] : []),
              { icon: `<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`, label: "Who's Invited", value: 'Everyone — bring friends & family' },
            ].map(item => (
              <div class="flex items-center gap-4 p-3 rounded-lg hover:bg-white/[0.02] transition-colors">
                <div class="w-9 h-9 rounded-lg bg-amber-500/10 text-amber-400 flex items-center justify-center flex-shrink-0">
                  <Fragment set:html={item.icon} />
                </div>
                <div>
                  <div class="text-white text-sm font-medium">{item.label}</div>
                  <div class="text-slate-500 text-[13px]">{item.value}</div>
                </div>
              </div>
            ))}
          </div>

          <a href={`/events/${event.slug}`} class="btn-primary">
            Learn More & Register
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </a>
        </div>

        <!-- Right: visual card -->
        <div class="reveal-right">
          <a href={`/events/${event.slug}`} class="block">
            <div class="floating-card p-10 text-center relative overflow-hidden shimmer" data-tilt>
              <!-- Ambient glow -->
              <div class="absolute top-0 right-0 w-40 h-40 bg-amber-500/5 rounded-full blur-3xl"></div>
              <div class="absolute bottom-0 left-0 w-32 h-32 bg-indigo-500/5 rounded-full blur-3xl"></div>

              <div class="relative z-10">
                <div class="w-16 h-16 rounded-xl bg-gradient-to-br from-amber-500/20 to-amber-600/10 flex items-center justify-center mx-auto mb-6 border border-amber-500/10">
                  <svg class="w-8 h-8 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.87c1.355 0 2.697.055 4.024.165C17.155 8.51 18 9.473 18 10.608v2.513m-3-4.87v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.38a48.474 48.474 0 00-6-.37c-2.032 0-4.034.126-6 .37m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.17c0 .62-.504 1.124-1.125 1.124H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z" />
                  </svg>
                </div>
                <h3 class="font-display text-2xl font-bold text-white tracking-tight mb-2">{event.title}</h3>
                {formattedDate && <p class="text-amber-400/60 text-sm mb-3">{formattedDate}</p>}
                {event.location && <p class="text-amber-400/40 text-xs mb-6">{event.location}</p>}
                <div class="w-12 h-px bg-white/10 mx-auto mb-6"></div>
                {event.description ? (
                  <p class="text-slate-500 text-[13px] leading-relaxed max-w-xs mx-auto">
                    {event.description.length > 150 ? event.description.slice(0, 150) + '…' : event.description}
                  </p>
                ) : (
                  <p class="text-slate-500 text-[13px] leading-relaxed max-w-xs mx-auto">
                    Click to learn more and register for this event.
                  </p>
                )}
              </div>
            </div>
          </a>
        </div>
      </div>
    ) : (
      <div class="text-center reveal">
        <div class="label-text mb-5">Events</div>
        <h2 class="heading-section text-white mb-6">Stay Tuned</h2>
        <p class="body-md max-w-xl mx-auto">
          We're planning something special. Check back soon for upcoming events, or subscribe to our newsletter to be the first to know.
        </p>
      </div>
    )}
  </div>
</section>
