---
---

<section id="contact" class="section-padding bg-white relative overflow-hidden">
  <div class="container-narrow">
    <div class="grid lg:grid-cols-2 gap-16">
      <!-- Left: Info -->
      <div class="reveal-left">
        <span class="label-text text-gold-600 mb-4 block">Get in Touch</span>
        <h2 class="heading-lg text-navy-900 mb-6">
          We'd Love to <span class="text-gold-600">Hear From You</span>
        </h2>
        <p class="body-md text-navy-500 mb-10">
          Whether you have questions about our ministry, want to learn about mission opportunities,
          or simply want to connect &mdash; we're here.
        </p>

        <div class="space-y-6 mb-10">
          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-navy-950 text-gold-400 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy-900 mb-1">Office Address</div>
              <div class="text-navy-500">1335 US Hwy. 68 E.<br />Benton, KY 42025</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-navy-950 text-gold-400 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy-900 mb-1">Mailing Address</div>
              <div class="text-navy-500">PO Box 790<br />Benton, KY 42025</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-navy-950 text-gold-400 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy-900 mb-1">Phone</div>
              <div class="text-navy-500">(270) 527-9445</div>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-12 h-12 rounded-xl bg-navy-950 text-gold-400 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
              </svg>
            </div>
            <div>
              <div class="font-semibold text-navy-900 mb-1">Email</div>
              <a href="mailto:contact@worldmissionsevangelism.com" class="text-gold-600 hover:text-gold-700 transition-colors">
                contact@worldmissionsevangelism.com
              </a>
            </div>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex gap-3">
          <a href="https://www.facebook.com/WorldMissionsandEvangelismInc" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-navy-100 text-navy-600 flex items-center justify-center hover:bg-navy-950 hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/world-missions-evangelism" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-navy-100 text-navy-600 flex items-center justify-center hover:bg-navy-950 hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/@WorldMissionsEvangel" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-full bg-navy-100 text-navy-600 flex items-center justify-center hover:bg-navy-950 hover:text-white transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="reveal-right">
        <div class="bg-navy-50/50 rounded-3xl p-8 md:p-10 border border-navy-100/50">
          <h3 class="heading-sm text-navy-900 mb-6">Send Us a Message</h3>
          <form class="space-y-5" onsubmit="return false;">
            <div class="grid sm:grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-navy-700 mb-2">First Name</label>
                <input type="text" class="w-full px-4 py-3 rounded-xl border border-navy-200 bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-400/20 transition-colors text-navy-900" />
              </div>
              <div>
                <label class="block text-sm font-medium text-navy-700 mb-2">Last Name</label>
                <input type="text" class="w-full px-4 py-3 rounded-xl border border-navy-200 bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-400/20 transition-colors text-navy-900" />
              </div>
            </div>
            <div>
              <label class="block text-sm font-medium text-navy-700 mb-2">Email</label>
              <input type="email" class="w-full px-4 py-3 rounded-xl border border-navy-200 bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-400/20 transition-colors text-navy-900" />
            </div>
            <div>
              <label class="block text-sm font-medium text-navy-700 mb-2">Phone</label>
              <input type="tel" class="w-full px-4 py-3 rounded-xl border border-navy-200 bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-400/20 transition-colors text-navy-900" />
            </div>
            <div>
              <label class="block text-sm font-medium text-navy-700 mb-2">Message</label>
              <textarea rows="4" class="w-full px-4 py-3 rounded-xl border border-navy-200 bg-white focus:border-gold-400 focus:ring-2 focus:ring-gold-400/20 transition-colors text-navy-900 resize-none"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full justify-center">
              Send Message
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 12L3.269 3.126A59.768 59.768 0 0121.485 12 59.77 59.77 0 013.27 20.876L5.999 12zm0 0h7.5" />
              </svg>
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
