---
---

<section class="py-20 relative">
  <div class="section-narrow text-center reveal">
    <div class="floating-card p-10 md:p-14 relative overflow-hidden">
      <!-- Ambient -->
      <div class="absolute top-0 right-0 w-40 h-40 bg-amber-500/5 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-32 h-32 bg-indigo-500/5 rounded-full blur-3xl"></div>

      <div class="relative z-10">
        <div class="label-text mb-4">Stay Connected</div>
        <h2 class="heading-card text-white mb-3">Join our newsletter</h2>
        <p class="text-slate-500 text-sm mb-8 max-w-md mx-auto">
          Bi-monthly field updates, prayer requests, impact stories, and ways to get involved.
        </p>

        <form class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto" onsubmit="return false;">
          <input type="text" placeholder="First name"
            class="flex-1 px-4 py-3 bg-white/[0.04] border border-white/[0.06] rounded-xl text-white text-sm placeholder:text-slate-600 focus:outline-none focus:border-amber-500/30 focus:ring-1 focus:ring-amber-500/20 transition-colors" />
          <input type="email" placeholder="Email address" required
            class="flex-1 px-4 py-3 bg-white/[0.04] border border-white/[0.06] rounded-xl text-white text-sm placeholder:text-slate-600 focus:outline-none focus:border-amber-500/30 focus:ring-1 focus:ring-amber-500/20 transition-colors" />
          <button type="submit" class="btn-primary !py-3 whitespace-nowrap">Subscribe</button>
        </form>

        <p class="text-slate-700 text-[11px] mt-4">We respect your privacy. Unsubscribe anytime.</p>
      </div>
    </div>
  </div>
</section>
