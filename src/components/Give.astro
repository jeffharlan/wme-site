---
const options = [
  { title: 'General Fund', desc: 'Support overall operations — resources go where needed most.', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>` },
  { title: 'Missionary Support', desc: 'Directly fund a missionary or project on the front lines.', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>` },
  { title: 'INSTAR Project', desc: 'Fuel the church planting movement across 1,400+ people groups.', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>` },
  { title: 'Last Tribe Initiative', desc: 'Send missionaries to the most remote, unreached people.', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>` },
];
---

<section id="give" class="py-28 md:py-36 relative">
  <div class="section-number" aria-hidden="true">08</div>
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>

  <div class="section-narrow">
    <div class="text-center mb-16 reveal">
      <div class="label-text mb-5">Partner With Us</div>
      <h2 class="heading-section text-white mb-4" data-text-reveal>
        Your generosity changes lives.
      </h2>
      <p class="body-md max-w-xl mx-auto">
        Every dollar goes directly toward planting churches, training leaders,
        and reaching communities that have never heard the Gospel.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-3 mb-12 stagger">
      {options.map((opt) => (
        <div class="floating-card-hover p-6 group glow-border" data-tilt>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-amber-500/10 text-amber-400 flex items-center justify-center flex-shrink-0 group-hover:bg-amber-500/20 transition-colors">
              <Fragment set:html={opt.icon} />
            </div>
            <div>
              <h3 class="text-white font-semibold tracking-tight mb-1">{opt.title}</h3>
              <p class="text-slate-500 text-[13px] leading-relaxed">{opt.desc}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="text-center reveal">
      <a href="https://give.ministrylinq.com/App/Giving/cashlinq-1409" target="_blank" rel="noopener noreferrer" class="btn-primary text-base">
        Give Now
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
      <p class="text-slate-600 text-xs mt-4">
        W.M.E., Inc. is a registered 501(c)(3) nonprofit. All donations are tax-deductible.
      </p>
    </div>
  </div>
</section>
