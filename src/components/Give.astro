---
const givingOptions = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`,
    title: 'General Fund',
    description: 'Support the overall operations of W.M.E., allowing us to allocate resources where they\'re needed most.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
    title: 'Missionary Support',
    description: 'Directly fund a specific missionary or project. Your investment sustains families serving on the front lines.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`,
    title: 'INSTAR Project',
    description: 'Fuel the church planting movement reaching 1,400+ people groups across Latin America and beyond.',
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>`,
    title: 'Last Tribe Initiative',
    description: 'Send trained missionaries to the most remote, unreached people groups on earth.',
  },
];
---

<section id="give" class="section-padding bg-warm-50 relative overflow-hidden">
  <div class="absolute top-0 right-0 w-96 h-96 bg-gold-200/30 rounded-full blur-3xl -translate-y-1/2"></div>

  <div class="container-narrow relative">
    <div class="text-center mb-16 reveal">
      <span class="label-text text-gold-600 mb-4 block">Partner With Us</span>
      <h2 class="heading-lg text-navy-900 mb-4">
        Your Generosity <span class="text-gold-600">Changes Lives</span>
      </h2>
      <p class="body-md text-navy-500 max-w-2xl mx-auto">
        Every dollar invested in W.M.E. goes directly toward planting churches, training leaders,
        and reaching communities that have never heard the Gospel.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6 mb-12 stagger-children">
      {givingOptions.map((option) => (
        <div class="card p-8 group">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-xl bg-gold-50 text-gold-600 flex items-center justify-center flex-shrink-0 group-hover:bg-gold-500 group-hover:text-white transition-all duration-300">
              <Fragment set:html={option.icon} />
            </div>
            <div>
              <h3 class="font-display text-xl text-navy-900 mb-2">{option.title}</h3>
              <p class="text-navy-500 leading-relaxed">{option.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA -->
    <div class="text-center reveal">
      <a
        href="https://give.ministrylinq.com/App/Giving/cashlinq-1409"
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary text-lg"
      >
        Give Now
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
      </a>
      <p class="text-navy-400 text-sm mt-4">
        World Missions & Evangelism, Inc. is a registered 501(c)(3) nonprofit. All donations are tax-deductible.
      </p>
    </div>
  </div>
</section>
