---
---

<section id="prayer" class="py-28 md:py-36 relative overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <!-- Ambient glow -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full"
       style="background: radial-gradient(circle, rgba(99, 102, 241, 0.06) 0%, transparent 70%);"></div>

  <div class="section-narrow text-center relative z-10">
    <div class="reveal">
      <div class="inline-block mb-8">
        <div class="glass-card p-3 rounded-xl">
          <img src="/images/instar-blue.jpg" alt="INSTAR Prayer" class="h-12 w-auto rounded-lg" loading="lazy" />
        </div>
      </div>

      <div class="label-text mb-5">Prayer Ministry</div>
      <h2 class="heading-section text-white mb-6">
        Every movement begins<br />
        <span class="gradient-text">on its knees.</span>
      </h2>
      <p class="body-lg max-w-2xl mx-auto mb-12">
        Our INSTAR Prayer network connects intercessors around the world with specific needs from the
        field — missionaries who need covering, communities awaiting breakthrough.
      </p>

      <div class="grid sm:grid-cols-3 gap-4 mb-12 max-w-2xl mx-auto stagger">
        {[
          { icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>`, title: 'Daily Requests', desc: 'Fresh prayer needs from the field' },
          { icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" /></svg>`, title: 'Global Network', desc: 'Intercessors in every time zone' },
          { icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" /></svg>`, title: 'Answered Prayers', desc: 'Testimonies of God\'s faithfulness' },
        ].map(item => (
          <div class="floating-card-hover p-6 text-center group">
            <div class="w-10 h-10 rounded-lg bg-indigo-500/10 text-indigo-400 flex items-center justify-center mx-auto mb-3 group-hover:bg-indigo-500/20 transition-colors">
              <Fragment set:html={item.icon} />
            </div>
            <h4 class="text-white font-semibold text-sm mb-1">{item.title}</h4>
            <p class="text-slate-500 text-[13px]">{item.desc}</p>
          </div>
        ))}
      </div>

      <a href="#contact" class="btn-primary">
        Join the Prayer Network
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
        </svg>
      </a>
    </div>
  </div>
</section>
