---
---

<section id="prayer" class="relative py-28 md:py-36 overflow-hidden">
  <!-- Background -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy-900 via-navy-950 to-navy-900"></div>

  <!-- Soft light rays effect -->
  <div class="absolute top-0 left-1/4 w-px h-full bg-gradient-to-b from-gold-400/20 via-transparent to-gold-400/10"></div>
  <div class="absolute top-0 right-1/3 w-px h-full bg-gradient-to-b from-transparent via-gold-400/10 to-transparent"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-12 text-center">
    <div class="reveal">
      <!-- INSTAR Prayer branding -->
      <div class="mb-8 flex justify-center">
        <div class="p-4 bg-white/5 rounded-2xl border border-white/10 backdrop-blur-sm">
          <img src="/images/instar-blue.jpg" alt="INSTAR Prayer" class="h-16 w-auto rounded-lg" loading="lazy" />
        </div>
      </div>

      <span class="label-text text-gold-400 mb-4 block">Prayer Ministry</span>
      <h2 class="heading-lg text-white mb-6">
        Every Movement Begins <span class="text-gold-400">on Its Knees</span>
      </h2>
      <p class="body-lg text-white/50 max-w-2xl mx-auto mb-8">
        Prayer is the foundation of everything we do. Our INSTAR Prayer network connects
        intercessors around the world with specific needs from the field &mdash; missionaries
        who need covering, communities awaiting breakthrough, and unreached peoples still in darkness.
      </p>

      <div class="grid sm:grid-cols-3 gap-6 mb-12">
        <div class="p-6 bg-white/[0.03] border border-white/[0.06] rounded-2xl">
          <svg class="w-8 h-8 text-gold-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <h4 class="text-white font-semibold mb-1">Daily Requests</h4>
          <p class="text-white/40 text-sm">Fresh prayer needs from missionaries in the field</p>
        </div>
        <div class="p-6 bg-white/[0.03] border border-white/[0.06] rounded-2xl">
          <svg class="w-8 h-8 text-gold-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418" />
          </svg>
          <h4 class="text-white font-semibold mb-1">Global Network</h4>
          <p class="text-white/40 text-sm">Intercessors connected across every time zone</p>
        </div>
        <div class="p-6 bg-white/[0.03] border border-white/[0.06] rounded-2xl">
          <svg class="w-8 h-8 text-gold-400 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
          </svg>
          <h4 class="text-white font-semibold mb-1">Answered Prayers</h4>
          <p class="text-white/40 text-sm">Testimonies of God's faithfulness in action</p>
        </div>
      </div>

      <a href="#contact" class="btn-primary">
        Join the Prayer Network
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
