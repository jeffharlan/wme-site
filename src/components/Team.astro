---
const staff = [
  { name: 'David Parish', role: 'President / CEO', image: '/images/david-parish.png', desc: 'Founded W.M.E. in 1988 with a vision to plant churches across the globe.' },
  { name: 'Jacob Harlan', role: 'Chief Operating Officer', image: '/images/jacob-harlan.png', desc: 'Leading day-to-day operations and strategic growth.' },
  { name: 'Trey Clendenen', role: 'Administrative Assistant', image: '/images/trey-clendenen.png', desc: 'Keeping the gears turning behind the scenes.' },
  { name: 'Renee Driskill', role: 'Development Director', image: '/images/renee-driskill.png', desc: 'Mobilizing prayer and building partnerships.' },
];

const coordinators = [
  { name: 'Keith Travis', role: 'Strategy Coordinator & Mentor', initials: 'KT' },
  { name: 'Randy Travis', role: 'Training Coordinator', initials: 'RT' },
  { name: 'David Fackler', role: 'Caribbean Regional', initials: 'DF' },
  { name: 'Troy & Tracy Allen', role: 'Southeast Asia Regional', initials: 'TA' },
  { name: 'Lisa Sims', role: 'North America Regional', initials: 'LS' },
];
---

<section id="team" class="py-28 md:py-36 relative">
  <!-- Section number watermark -->
  <div class="section-number" aria-hidden="true">05</div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="section-container relative z-10">
    <div class="text-center mb-16 reveal">
      <div class="label-text mb-5">Leadership</div>
      <h2 class="heading-section text-white mb-4" data-text-reveal>
        The people behind the mission.
      </h2>
    </div>

    <!-- Scripture -->
    <div class="text-center mb-14 reveal">
      <div class="glass-card inline-block px-8 py-5 rounded-xl max-w-2xl">
        <p class="text-slate-400 italic font-display text-sm leading-relaxed">
          "Whatever city you enter and they receive you... heal those in it who are sick, and say to them,
          'The kingdom of God has come near to you.'"
        </p>
        <span class="text-amber-400/40 text-xs mt-2 block font-sans">&mdash; Luke 10:8-9</span>
      </div>
    </div>

    <!-- Staff grid with 3D tilt -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-4 mb-12 stagger">
      {staff.map((member) => (
        <div class="floating-card-hover p-6 group text-center glow-border" data-tilt>
          <div class="w-28 h-28 rounded-2xl overflow-hidden mx-auto mb-5 ring-1 ring-white/[0.06] group-hover:ring-amber-500/20 transition-all duration-500 group-hover:scale-105">
            <img src={member.image} alt={member.name} class="img-cinematic" loading="lazy" />
          </div>
          <h3 class="text-white font-semibold tracking-tight mb-0.5">{member.name}</h3>
          <p class="text-amber-400/70 text-xs font-medium mb-3">{member.role}</p>
          <p class="text-slate-500 text-[13px] leading-relaxed">{member.desc}</p>
        </div>
      ))}
    </div>

    <!-- Regional coordinators -->
    <div class="reveal">
      <div class="floating-card p-6 md:p-8">
        <h3 class="text-white font-semibold tracking-tight text-center mb-6">Regional Coordinators & Strategy Team</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-2">
          {coordinators.map((c) => (
            <div class="flex items-center gap-3 p-3 rounded-lg hover:bg-white/[0.03] transition-colors group">
              <div class="w-9 h-9 rounded-lg bg-amber-500/10 text-amber-400 flex items-center justify-center flex-shrink-0 text-xs font-bold group-hover:bg-amber-500/20 group-hover:scale-110 transition-all duration-300">
                {c.initials}
              </div>
              <div class="min-w-0">
                <div class="text-white text-sm font-medium truncate">{c.name}</div>
                <div class="text-slate-500 text-[11px] truncate">{c.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
