---
const staff = [
  {
    name: 'David Parish',
    role: 'President / CEO',
    image: '/images/david-parish.png',
    description: 'Founded W.M.E. in 1988 with a vision to plant churches across the globe.',
  },
  {
    name: 'Jacob Harlan',
    role: 'Chief Operating Officer',
    image: '/images/jacob-harlan.png',
    description: 'Leading day-to-day operations and strategic growth of the ministry.',
  },
  {
    name: 'Trey Clendenen',
    role: 'Administrative Assistant',
    image: '/images/trey-clendenen.png',
    description: 'Keeping the gears turning behind the scenes.',
  },
  {
    name: 'Renee Driskill',
    role: 'Development Director / Prayer Coordinator',
    image: '/images/renee-driskill.png',
    description: 'Mobilizing prayer and building partnerships that fuel the mission.',
  },
];

const coordinators = [
  { name: 'Keith Travis', role: 'Strategy Coordinator & Team Mentor' },
  { name: 'Randy Travis', role: 'Training Coordinator' },
  { name: 'David Fackler', role: 'Caribbean Regional Coordinator' },
  { name: 'Troy & Tracy Allen', role: 'Southeast Asia Regional Coordinator' },
  { name: 'Lisa Sims', role: 'North America Regional Coordinator' },
];
---

<section id="team" class="section-padding bg-warm-50 relative overflow-hidden">
  <div class="absolute top-0 left-0 w-1/3 h-full bg-gradient-to-r from-gold-50/30 to-transparent"></div>

  <div class="container-wide relative">
    <div class="text-center mb-16 reveal">
      <span class="label-text text-gold-600 mb-4 block">Our Team</span>
      <h2 class="heading-lg text-navy-900 mb-4">
        The People Behind <span class="text-gold-600">the Mission</span>
      </h2>
      <p class="body-md text-navy-500 max-w-2xl mx-auto">
        Dedicated leaders committed to reaching the unreached and equipping the next generation of church planters.
      </p>
    </div>

    <!-- Scripture -->
    <div class="text-center mb-16 reveal">
      <p class="italic text-navy-400 max-w-2xl mx-auto body-md">
        "Whatever city you enter and they receive you, eat what is set before you; heal those in it who are sick,
        and say to them, 'The kingdom of God has come near to you.'"
      </p>
      <span class="text-gold-500 text-sm mt-3 block">&mdash; Luke 10:8-9</span>
    </div>

    <!-- Staff grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16 stagger-children">
      {staff.map((member) => (
        <div class="group text-center">
          <div class="relative mb-6 mx-auto w-48 h-48">
            <div class="w-full h-full rounded-2xl overflow-hidden bg-navy-100 shadow-lg group-hover:shadow-xl transition-all duration-500 group-hover:-translate-y-1">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-700"
                loading="lazy"
              />
            </div>
            <!-- Gold accent corner -->
            <div class="absolute -bottom-2 -right-2 w-12 h-12 bg-gold-400 rounded-xl -z-10 group-hover:scale-110 transition-transform duration-300"></div>
          </div>
          <h3 class="font-display text-xl text-navy-900 mb-1">{member.name}</h3>
          <p class="text-gold-600 font-medium text-sm mb-2">{member.role}</p>
          <p class="text-navy-500 text-sm leading-relaxed">{member.description}</p>
        </div>
      ))}
    </div>

    <!-- Regional coordinators -->
    <div class="reveal">
      <div class="bg-white rounded-2xl p-8 md:p-10 shadow-sm border border-navy-100/50">
        <h3 class="heading-sm text-navy-900 mb-6 text-center">Regional Coordinators & Strategy Team</h3>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {coordinators.map((coord) => (
            <div class="flex items-center gap-4 p-4 rounded-xl hover:bg-navy-50 transition-colors duration-300">
              <div class="w-10 h-10 rounded-full bg-navy-950 flex items-center justify-center flex-shrink-0">
                <span class="text-gold-400 font-bold text-sm">{coord.name.charAt(0)}</span>
              </div>
              <div>
                <div class="font-semibold text-navy-900 text-sm">{coord.name}</div>
                <div class="text-navy-500 text-xs">{coord.role}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
