---
const stats = [
  { number: 6132, suffix: '+', label: 'Churches & Bible Studies', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z" /></svg>` },
  { number: 23000, suffix: '+', label: 'Lives Committed to Christ', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>` },
  { number: 18000, suffix: '+', label: 'Baptisms Worldwide', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.362 5.214A8.252 8.252 0 0112 21 8.25 8.25 0 016.038 7.048 8.287 8.287 0 009 9.6a8.983 8.983 0 013.361-6.867 8.21 8.21 0 003 2.48z" /></svg>` },
  { number: 34000, suffix: '+', label: 'Total Participants', icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>` },
];
---

<section id="impact" class="py-28 md:py-36 relative">
  <!-- Subtle divider glow -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>

  <div class="section-container">
    <div class="text-center mb-16 reveal">
      <div class="label-text mb-5">By The Numbers</div>
      <h2 class="heading-section text-white mb-4">
        Measured impact.<br class="hidden md:block" />
        <span class="gradient-text">Real transformation.</span>
      </h2>
      <p class="body-md max-w-xl mx-auto">
        Results from the first nine years of our INSTAR initiative alone.
      </p>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 stagger">
      {stats.map((stat) => (
        <div class="floating-card-hover p-8 text-center group">
          <div class="w-10 h-10 rounded-lg bg-amber-500/10 text-amber-400 flex items-center justify-center mx-auto mb-5 group-hover:bg-amber-500/20 transition-colors duration-300">
            <Fragment set:html={stat.icon} />
          </div>
          <div class="counter text-3xl md:text-4xl font-extrabold text-white tracking-tight mb-2" data-count={stat.number} data-suffix={stat.suffix}>
            0{stat.suffix}
          </div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500">
            {stat.label}
          </div>
        </div>
      ))}
    </div>

    <!-- Scripture -->
    <div class="mt-16 text-center reveal">
      <div class="glass-card inline-block px-8 py-5 rounded-xl">
        <p class="text-slate-400 italic font-display text-base">
          "For the kingdom of God is not a matter of eating & drinking but of righteousness, peace & joy in the Holy Spirit."
        </p>
        <span class="text-amber-400/40 text-xs mt-2 block font-sans">&mdash; Romans 14:17 ESV</span>
      </div>
    </div>
  </div>
</section>
