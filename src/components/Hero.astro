---
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden">
  <!-- Background image collage with overlay -->
  <div class="absolute inset-0">
    <div class="absolute inset-0 grid grid-cols-3 grid-rows-2 opacity-20">
      <div class="overflow-hidden"><img src="/images/missionary-teaching.jpg" alt="" class="img-cinematic" loading="eager" /></div>
      <div class="overflow-hidden"><img src="/images/keith-juanita.jpg" alt="" class="img-cinematic" loading="eager" /></div>
      <div class="overflow-hidden"><img src="/images/palabra-vida.jpg" alt="" class="img-cinematic" loading="eager" /></div>
      <div class="overflow-hidden"><img src="/images/missionary-goodnight.jpg" alt="" class="img-cinematic" loading="eager" /></div>
      <div class="overflow-hidden"><img src="/images/missionary-crowder.jpg" alt="" class="img-cinematic" loading="eager" /></div>
      <div class="overflow-hidden"><img src="/images/campo-mission.jpg" alt="" class="img-cinematic" loading="eager" /></div>
    </div>
    <!-- Heavy gradient overlay for depth -->
    <div class="absolute inset-0 bg-gradient-to-b from-surface-0 via-surface-0/80 to-surface-0"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-surface-0/60 via-transparent to-surface-0/60"></div>
  </div>

  <!-- Ambient glow -->
  <div class="absolute top-1/3 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full opacity-30"
       style="background: radial-gradient(circle, rgba(212, 160, 23, 0.15) 0%, transparent 70%);"></div>

  <!-- Content -->
  <div class="relative z-10 section-container text-center pt-20">
    <!-- Eyebrow badge -->
    <div class="inline-flex items-center gap-2.5 px-5 py-2 glass-card rounded-full mb-10" style="animation: fadeIn 1s ease-out 0.2s both;">
      <span class="status-dot-pulse"></span>
      <span class="text-white/50 text-[13px] font-medium tracking-wide">Since 1988 &mdash; Active across 5 continents</span>
    </div>

    <!-- Main heading -->
    <h1 class="heading-display text-white max-w-4xl mx-auto mb-8" style="animation: fadeUp 0.8s ease-out 0.4s both;">
      Planting Churches.<br />
      <span class="gradient-text">Changing Nations.</span>
    </h1>

    <!-- Subheading -->
    <p class="text-lg md:text-xl text-slate-400 max-w-2xl mx-auto mb-12 font-light leading-relaxed" style="animation: fadeUp 0.8s ease-out 0.6s both;">
      World Missions & Evangelism facilitates disciple-making movements and church planting across five continents, transforming communities one life at a time.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row gap-4 justify-center mb-20" style="animation: fadeUp 0.8s ease-out 0.8s both;">
      <a href="#about" class="btn-primary text-base">
        Discover Our Story
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
      <a href="#give" class="btn-ghost text-base">
        Become a Partner
      </a>
    </div>

    <!-- Impact stats strip -->
    <div class="glass-card p-1 rounded-2xl max-w-3xl mx-auto" style="animation: fadeUp 0.8s ease-out 1s both;">
      <div class="grid grid-cols-3 divide-x divide-white/[0.06]">
        <div class="py-6 px-4 text-center">
          <div class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">6,132<span class="text-amber-400">+</span></div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mt-1">Churches Planted</div>
        </div>
        <div class="py-6 px-4 text-center">
          <div class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">23,000<span class="text-amber-400">+</span></div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mt-1">Lives Changed</div>
        </div>
        <div class="py-6 px-4 text-center">
          <div class="text-2xl md:text-3xl font-extrabold text-white tracking-tight">18,000<span class="text-amber-400">+</span></div>
          <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mt-1">Baptisms</div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2" style="animation: fadeIn 1.5s ease-out 1.5s both;">
    <div class="w-5 h-8 rounded-full border border-white/20 flex justify-center pt-1.5">
      <div class="w-1 h-2 rounded-full bg-white/40 animate-bounce"></div>
    </div>
  </div>
</section>

<style>
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
</style>
