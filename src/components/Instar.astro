---
const pillars = [
  { num: '01', title: 'Intercession', subtitle: 'Prayer & Identification', desc: 'Prayer mobilization and region mapping to understand the spiritual landscape of every community we enter.' },
  { num: '02', title: 'Networking', subtitle: 'Strategic Partnerships', desc: 'Building partnerships with existing evangelical ministries to create a united front in reaching the unreached.' },
  { num: '03', title: 'Serving', subtitle: 'Meeting Real Needs', desc: 'Water, medical, orphan care, and education programs that open doors for the Gospel and demonstrate God\'s love.' },
  { num: '04', title: 'Training', subtitle: 'Equipping Leaders', desc: 'Church planting and disciple-making curriculum with hands-on mentoring — equipping leaders who equip others.' },
  { num: '05', title: 'Assisting', subtitle: 'Ongoing Support', desc: 'Field support with transparent documentation and progress tracking to ensure lasting, accountable growth.' },
];
---

<section id="instar" class="py-28 md:py-36 relative">
  <!-- Section number watermark -->
  <div class="section-number" aria-hidden="true">03</div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="section-container relative z-10">
    <!-- Header -->
    <div class="max-w-3xl mb-20 reveal">
      <div class="label-text mb-5">The INSTAR Initiative</div>
      <h2 class="heading-section text-white mb-6" data-text-reveal>
        A proven strategy to reach every nation.
      </h2>
      <p class="body-lg">
        Launched in Honduras in 2008, INSTAR proved that reproducing churches could reach entire regions.
        From 266 groups in 2012 to over <span class="text-white font-medium">6,000+</span> today, the model works.
      </p>
    </div>

    <!-- Two-column: Pillars + Visual -->
    <div class="grid lg:grid-cols-5 gap-12 lg:gap-8">
      <!-- Pillars -->
      <div class="lg:col-span-3 space-y-3 stagger">
        {pillars.map((p) => (
          <div class="floating-card-hover p-6 group glow-border">
            <div class="flex items-start gap-5">
              <div class="text-amber-400/30 font-mono text-xs font-bold mt-1 w-6 flex-shrink-0 group-hover:text-amber-400/70 transition-colors">{p.num}</div>
              <div class="flex-1 min-w-0">
                <div class="flex items-baseline gap-3 mb-1.5">
                  <h3 class="text-white font-semibold tracking-tight">{p.title}</h3>
                  <span class="text-slate-600 text-[13px] hidden sm:inline">{p.subtitle}</span>
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">{p.desc}</p>
              </div>
              <svg class="w-4 h-4 text-slate-700 group-hover:text-amber-400 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-all flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </div>
          </div>
        ))}
      </div>

      <!-- Right side: Key stats + image -->
      <div class="lg:col-span-2 reveal-right">
        <!-- INSTAR map -->
        <div class="floating-card overflow-hidden rounded-xl mb-4 shimmer">
          <img src="/images/instar-goal-map.jpg" alt="INSTAR Global Reach" class="w-full h-auto" loading="lazy" />
          <div class="p-5">
            <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mb-2">INSTAR Coverage</div>
            <p class="text-slate-400 text-sm">21 nations across Latin America, the Caribbean, Southeast Asia, Africa, and North America.</p>
          </div>
        </div>

        <!-- Key metrics -->
        <div class="grid grid-cols-2 gap-3">
          <div class="floating-card p-5 text-center group hover:border-amber-500/10 transition-colors" data-tilt>
            <div class="text-2xl font-extrabold text-white tracking-tight group-hover:scale-110 transition-transform">1,400<span class="text-amber-400">+</span></div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mt-1">People Groups</div>
          </div>
          <div class="floating-card p-5 text-center group hover:border-amber-500/10 transition-colors" data-tilt>
            <div class="text-2xl font-extrabold text-white tracking-tight group-hover:scale-110 transition-transform">50<span class="text-amber-400">+</span></div>
            <div class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-500 mt-1">Denominations Trained</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
