---
const regions = [
  {
    name: 'Latin America',
    icon: '/images/icon-latin-america.png',
    description: '21 nations from Mexico through South America, including Honduras where INSTAR began.',
    countries: 'Honduras, Mexico, Guatemala, El Salvador, Nicaragua, Costa Rica, Panama, Colombia, Venezuela, Ecuador, Peru, Bolivia, Chile, Argentina, Uruguay, Paraguay, Brazil',
    color: 'from-emerald-500 to-teal-600',
    missionaries: 'Brown-Espinoza, Crowder, K. Travis, R. Travis, Rodrigues, and more',
  },
  {
    name: 'Southeast Asia',
    icon: '/images/icon-southeast-asia.png',
    description: 'The SEASTAR incarnation of INSTAR, bringing church planting movements to Asia.',
    countries: 'Multiple nations across Southeast Asia',
    color: 'from-amber-500 to-orange-600',
    missionaries: 'Gunn, Allen',
  },
  {
    name: 'Africa',
    icon: '/images/icon-africa.png',
    description: 'Reaching communities across the African continent with the Gospel and practical support.',
    countries: 'South Africa and expanding regions',
    color: 'from-rose-500 to-red-600',
    missionaries: 'Goodnight, Tocco, Uliano, Watson',
  },
  {
    name: 'North America',
    icon: '/images/icon-north-america.png',
    description: 'Ministry to indigenous communities and underserved populations across the continent.',
    countries: 'United States, including Native American communities',
    color: 'from-blue-500 to-indigo-600',
    missionaries: 'Allen, God\'s Promises, Jim & Cindy Lilly, and more',
  },
  {
    name: 'Caribbean',
    icon: '/images/events-icon.png',
    description: 'Island nations receiving church planting training and community development support.',
    countries: 'Caribbean Islands',
    color: 'from-violet-500 to-purple-600',
    missionaries: 'David Fackler, Elbin Castillo',
  },
];
---

<section id="regions" class="section-padding bg-white relative overflow-hidden">
  <div class="container-wide">
    <div class="text-center mb-16 reveal">
      <span class="label-text text-gold-600 mb-4 block">Where We Serve</span>
      <h2 class="heading-lg text-navy-900 mb-4">
        Five Regions. <span class="text-gold-600">One Mission.</span>
      </h2>
      <p class="body-md text-navy-500 max-w-2xl mx-auto">
        From the mountains of Honduras to the islands of the Caribbean, W.M.E. is actively
        planting churches and training leaders across the globe.
      </p>
    </div>

    <!-- Region map image -->
    <div class="mb-16 reveal">
      <div class="relative max-w-4xl mx-auto">
        <div class="rounded-3xl overflow-hidden shadow-2xl shadow-navy-900/10 border border-navy-100">
          <img
            src="/images/instar-goal-map.jpg"
            alt="INSTAR Global Reach Map"
            class="w-full h-auto"
            loading="lazy"
          />
        </div>
      </div>
    </div>

    <!-- Region cards -->
    <div class="flex flex-wrap justify-center gap-6 stagger-children">
      {regions.map((region, i) => (
        <div class="card group w-full md:w-[calc(50%-12px)] lg:w-[calc(33.333%-16px)]">
          <div class={`h-2 bg-gradient-to-r ${region.color}`}></div>
          <div class="p-8">
            <div class="flex items-center gap-4 mb-4">
              <div class="w-14 h-14 rounded-xl bg-navy-50 p-2 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                <img src={region.icon} alt={region.name} class="w-10 h-10 object-contain" loading="lazy" />
              </div>
              <h3 class="heading-sm text-navy-900">{region.name}</h3>
            </div>
            <p class="text-navy-600 mb-4 leading-relaxed">{region.description}</p>
            <div class="pt-4 border-t border-navy-100/50">
              <span class="text-xs font-semibold text-navy-400 uppercase tracking-wider">Key Missionaries</span>
              <p class="text-sm text-navy-500 mt-1">{region.missionaries}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Last Tribe callout -->
    <div class="mt-16 reveal">
      <div class="bg-gradient-to-r from-navy-950 to-navy-800 rounded-3xl p-10 md:p-14 text-white relative overflow-hidden">
        <div class="absolute top-0 right-0 w-64 h-64 bg-gold-500/10 rounded-full blur-3xl"></div>
        <div class="relative z-10 max-w-3xl">
          <span class="label-text text-gold-400 mb-4 block">The Last Tribe Initiative</span>
          <h3 class="heading-md text-white mb-4">Reaching the Unreached</h3>
          <p class="body-md text-white/60 mb-6">
            Some communities have never heard the Gospel &mdash; not even once. The Last Tribe Initiative
            maps, researches, and deploys trained missionaries to the most remote and unreached people
            groups on earth, building coalitions with other missions agencies to ensure no tribe is forgotten.
          </p>
          <a href="#give" class="btn-primary">
            Support This Mission
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
