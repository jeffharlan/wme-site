---
const regions = [
  { name: 'Latin America', icon: '/images/icon-latin-america.png', desc: '21 nations from Mexico through South America — where INSTAR began in Honduras.', missionaries: 'Brown-Espinoza, Crowder, Travis, Rodrigues', color: 'from-emerald-400 to-teal-500' },
  { name: 'Southeast Asia', icon: '/images/icon-southeast-asia.png', desc: 'The SEASTAR incarnation bringing church planting movements across Asia.', missionaries: 'Gunn, Allen', color: 'from-amber-400 to-orange-500' },
  { name: 'Africa', icon: '/images/icon-africa.png', desc: 'Reaching communities with the Gospel and practical support across the continent.', missionaries: 'Goodnight, Tocco, Uliano, Watson', color: 'from-rose-400 to-red-500' },
  { name: 'North America', icon: '/images/icon-north-america.png', desc: 'Ministry to indigenous communities and underserved populations.', missionaries: 'Allen, God\'s Promises, Lilly', color: 'from-blue-400 to-indigo-500' },
  { name: 'Caribbean', icon: '/images/events-icon.png', desc: 'Island nations receiving church planting training and community development.', missionaries: 'Fackler, Castillo', color: 'from-violet-400 to-purple-500' },
];
---

<section id="regions" class="py-28 md:py-36 relative">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="section-container">
    <div class="text-center mb-16 reveal">
      <div class="label-text mb-5">Where We Serve</div>
      <h2 class="heading-section text-white mb-4">
        Five regions. <span class="gradient-text">One mission.</span>
      </h2>
      <p class="body-md max-w-xl mx-auto">
        From the mountains of Honduras to the islands of the Caribbean.
      </p>
    </div>

    <!-- Region cards — flex wrap centered -->
    <div class="flex flex-wrap justify-center gap-4 stagger">
      {regions.map((region) => (
        <div class="floating-card-hover w-full md:w-[calc(50%-8px)] lg:w-[calc(33.333%-11px)] p-6 group">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-11 h-11 rounded-lg bg-white/[0.04] p-2 flex items-center justify-center group-hover:bg-white/[0.08] transition-colors">
              <img src={region.icon} alt={region.name} class="w-7 h-7 object-contain opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" />
            </div>
            <div>
              <h3 class="text-white font-semibold tracking-tight">{region.name}</h3>
              <div class={`h-0.5 w-8 rounded-full bg-gradient-to-r ${region.color} mt-1`}></div>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">{region.desc}</p>
          <div class="pt-3 border-t border-white/[0.04]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600">Key missionaries</span>
            <p class="text-slate-500 text-xs mt-0.5">{region.missionaries}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Last Tribe callout -->
    <div class="mt-16 reveal">
      <div class="relative overflow-hidden rounded-xl">
        <!-- Background image -->
        <div class="absolute inset-0">
          <img src="/images/community-prayer.jpg" alt="" class="img-cinematic opacity-50" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-r from-surface-0/80 via-surface-0/50 to-surface-0/70"></div>
        </div>
        <div class="relative z-10 p-10 md:p-14">
          <div class="max-w-2xl">
            <div class="label-text mb-4">The Last Tribe Initiative</div>
            <h3 class="heading-card text-white mb-4">Reaching the unreached</h3>
            <p class="body-sm text-slate-400 mb-6 max-w-lg">
              Some communities have never heard the Gospel. The Last Tribe Initiative maps, researches, and deploys
              trained missionaries to the most remote people groups on earth.
            </p>
            <a href="#give" class="btn-primary">
              Support This Mission
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
