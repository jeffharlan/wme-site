---
const regions = [
  { name: 'Latin America', icon: '/images/icon-latin-america.png', desc: '21 nations from Mexico through South America — where INSTAR began in Honduras.', missionaries: 'Brown-Espinoza, Crowder, Travis, Rodrigues', color: 'from-emerald-400 to-teal-500' },
  { name: 'Southeast Asia', icon: '/images/icon-southeast-asia.png', desc: 'The SEASTAR incarnation bringing church planting movements across Asia.', missionaries: 'Gunn, Allen', color: 'from-amber-400 to-orange-500' },
  { name: 'Africa', icon: '/images/icon-africa.png', desc: 'Reaching communities with the Gospel and practical support across the continent.', missionaries: 'Goodnight, Tocco, Uliano, Watson', color: 'from-rose-400 to-red-500' },
  { name: 'North America', icon: '/images/icon-north-america.png', desc: 'Ministry to indigenous communities and underserved populations.', missionaries: "Allen, God's Promises, Lilly", color: 'from-blue-400 to-indigo-500' },
  { name: 'Caribbean', icon: '/images/events-icon.png', desc: 'Island nations receiving church planting training and community development.', missionaries: 'Fackler, Castillo', color: 'from-violet-400 to-purple-500' },
];
---

<section id="regions" class="py-28 md:py-36 relative">
  <!-- Section number watermark -->
  <div class="section-number" aria-hidden="true">04</div>

  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-white/5 to-transparent"></div>

  <div class="section-container relative z-10">
    <div class="text-center mb-16 reveal">
      <div class="label-text mb-5">Where We Serve</div>
      <h2 class="heading-section text-white mb-4" data-text-reveal>
        Five regions. One mission.
      </h2>
      <p class="body-md max-w-xl mx-auto">
        From the mountains of Honduras to the islands of the Caribbean.
      </p>
    </div>

    <!-- Animated World Map -->
    <div class="mb-16 reveal-scale">
      <div class="glass-card p-6 md:p-10 rounded-2xl relative overflow-hidden">
        <!-- Faint background map image -->
        <div class="absolute inset-0 opacity-10">
          <img src="/images/instar-goal-map.jpg" alt="" class="w-full h-full object-cover" loading="lazy" />
        </div>

        <svg viewBox="0 0 900 420" class="w-full h-auto relative z-10" aria-label="WME Global Reach Map">
          <defs>
            <filter id="glow">
              <feGaussianBlur stdDeviation="3" result="blur" />
              <feMerge>
                <feMergeNode in="blur" />
                <feMergeNode in="SourceGraphic" />
              </feMerge>
            </filter>
            <radialGradient id="dotGlow" cx="50%" cy="50%" r="50%">
              <stop offset="0%" stop-color="#d4a017" stop-opacity="0.8" />
              <stop offset="100%" stop-color="#d4a017" stop-opacity="0" />
            </radialGradient>
          </defs>

          <!-- Connection arcs from HQ to regions -->
          <!-- HQ (Benton, KY) to Latin America -->
          <path d="M220,170 Q200,220 210,280" fill="none" stroke="#d4a017" stroke-width="1" stroke-opacity="0.25" class="map-line-flow" />
          <!-- HQ to Caribbean -->
          <path d="M220,170 Q240,200 250,225" fill="none" stroke="#d4a017" stroke-width="1" stroke-opacity="0.25" class="map-line-flow" style="animation-delay: 0.3s;" />
          <!-- HQ to Africa -->
          <path d="M220,170 Q400,60 470,260" fill="none" stroke="#d4a017" stroke-width="1" stroke-opacity="0.25" class="map-line-flow" style="animation-delay: 0.6s;" />
          <!-- HQ to Southeast Asia -->
          <path d="M220,170 Q500,40 700,240" fill="none" stroke="#d4a017" stroke-width="1" stroke-opacity="0.25" class="map-line-flow" style="animation-delay: 0.9s;" />
          <!-- HQ to North America (general) -->
          <path d="M220,170 Q180,150 160,165" fill="none" stroke="#d4a017" stroke-width="1" stroke-opacity="0.25" class="map-line-flow" style="animation-delay: 1.2s;" />

          <!-- HQ Dot (Benton, KY) -->
          <circle cx="220" cy="170" r="5" fill="#d4a017" filter="url(#glow)" />
          <circle cx="220" cy="170" r="12" fill="url(#dotGlow)" class="map-dot-pulse" />
          <text x="220" y="158" text-anchor="middle" fill="white" font-size="9" font-weight="600" opacity="0.5" font-family="Inter, sans-serif">HQ</text>

          <!-- Latin America -->
          <circle cx="210" cy="280" r="4" fill="#10b981" filter="url(#glow)" />
          <circle cx="210" cy="280" r="10" fill="none" stroke="#10b981" stroke-width="0.5" stroke-opacity="0.4" class="map-dot-pulse" style="animation-delay: 0.5s;" />
          <text x="210" y="298" text-anchor="middle" fill="#10b981" font-size="8" font-weight="500" opacity="0.7" font-family="Inter, sans-serif">Latin America</text>

          <!-- Caribbean -->
          <circle cx="250" cy="225" r="3.5" fill="#8b5cf6" filter="url(#glow)" />
          <circle cx="250" cy="225" r="9" fill="none" stroke="#8b5cf6" stroke-width="0.5" stroke-opacity="0.4" class="map-dot-pulse" style="animation-delay: 0.8s;" />
          <text x="270" y="220" text-anchor="start" fill="#8b5cf6" font-size="8" font-weight="500" opacity="0.7" font-family="Inter, sans-serif">Caribbean</text>

          <!-- Africa -->
          <circle cx="470" cy="260" r="4" fill="#f43f5e" filter="url(#glow)" />
          <circle cx="470" cy="260" r="10" fill="none" stroke="#f43f5e" stroke-width="0.5" stroke-opacity="0.4" class="map-dot-pulse" style="animation-delay: 1.1s;" />
          <text x="470" y="278" text-anchor="middle" fill="#f43f5e" font-size="8" font-weight="500" opacity="0.7" font-family="Inter, sans-serif">Africa</text>

          <!-- Southeast Asia -->
          <circle cx="700" cy="240" r="4" fill="#f59e0b" filter="url(#glow)" />
          <circle cx="700" cy="240" r="10" fill="none" stroke="#f59e0b" stroke-width="0.5" stroke-opacity="0.4" class="map-dot-pulse" style="animation-delay: 1.4s;" />
          <text x="700" y="258" text-anchor="middle" fill="#f59e0b" font-size="8" font-weight="500" opacity="0.7" font-family="Inter, sans-serif">Southeast Asia</text>

          <!-- North America -->
          <circle cx="160" cy="165" r="3.5" fill="#3b82f6" filter="url(#glow)" />
          <circle cx="160" cy="165" r="9" fill="none" stroke="#3b82f6" stroke-width="0.5" stroke-opacity="0.4" class="map-dot-pulse" style="animation-delay: 1.7s;" />
          <text x="130" y="158" text-anchor="end" fill="#3b82f6" font-size="8" font-weight="500" opacity="0.7" font-family="Inter, sans-serif">N. America</text>

          <!-- Subtle scatter dots for atmosphere -->
          {Array.from({length: 30}).map(() => (
            <circle
              cx={100 + Math.random() * 700}
              cy={100 + Math.random() * 280}
              r="0.8"
              fill="white"
              opacity={0.05 + Math.random() * 0.08}
            />
          ))}
        </svg>
      </div>
    </div>

    <!-- Region cards -->
    <div class="flex flex-wrap justify-center gap-4 stagger">
      {regions.map((region) => (
        <div class="floating-card-hover w-full md:w-[calc(50%-8px)] lg:w-[calc(33.333%-11px)] p-6 group glow-border" data-tilt>
          <div class="flex items-center gap-4 mb-4">
            <div class="w-11 h-11 rounded-lg bg-white/[0.04] p-2 flex items-center justify-center group-hover:bg-white/[0.08] transition-colors">
              <img src={region.icon} alt={region.name} class="w-7 h-7 object-contain opacity-70 group-hover:opacity-100 transition-opacity" loading="lazy" />
            </div>
            <div>
              <h3 class="text-white font-semibold tracking-tight">{region.name}</h3>
              <div class={`h-0.5 w-8 rounded-full bg-gradient-to-r ${region.color} mt-1`}></div>
            </div>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed mb-4">{region.desc}</p>
          <div class="pt-3 border-t border-white/[0.04]">
            <span class="text-[11px] font-semibold uppercase tracking-[0.12em] text-slate-600">Key missionaries</span>
            <p class="text-slate-500 text-xs mt-0.5">{region.missionaries}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Last Tribe callout -->
    <div class="mt-16 reveal">
      <div class="relative overflow-hidden rounded-xl">
        <!-- Background image -->
        <div class="absolute inset-0">
          <img src="/images/community-prayer.jpg" alt="" class="img-cinematic opacity-50" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-r from-surface-0/80 via-surface-0/50 to-surface-0/70"></div>
        </div>
        <div class="relative z-10 p-10 md:p-14">
          <div class="max-w-2xl">
            <div class="label-text mb-4">The Last Tribe Initiative</div>
            <h3 class="heading-card text-white mb-4">Reaching the unreached</h3>
            <p class="body-sm text-slate-400 mb-6 max-w-lg">
              Some communities have never heard the Gospel. The Last Tribe Initiative maps, researches, and deploys
              trained missionaries to the most remote people groups on earth.
            </p>
            <a href="#give" class="btn-primary">
              Support This Mission
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
