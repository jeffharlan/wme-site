---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { label: 'About', href: '#about' },
  { label: 'INSTAR', href: '#instar' },
  { label: 'Our Team', href: '#team' },
  { label: 'Events', href: '#events' },
  { label: 'Give', href: '#give' },
  { label: 'Contact', href: '#contact' },
];

const regions = [
  { label: 'Latin America', href: '#regions' },
  { label: 'Southeast Asia', href: '#regions' },
  { label: 'Africa', href: '#regions' },
  { label: 'North America', href: '#regions' },
  { label: 'Caribbean', href: '#regions' },
];

const resources = [
  { label: 'Discovery Bible Study', href: '#' },
  { label: 'Megavoice Literature', href: '#' },
  { label: 'Books', href: '#' },
  { label: 'Videos', href: '#' },
  { label: 'Prayer Network', href: '#prayer' },
];
---

<footer class="bg-navy-950 text-white">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <!-- Main footer content -->
    <div class="py-16 grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-16">
      <!-- Brand column -->
      <div class="col-span-2 md:col-span-1">
        <img src="/images/wme-logo.png" alt="World Missions & Evangelism" class="h-10 mb-6 brightness-0 invert opacity-80" />
        <p class="text-white/40 text-sm leading-relaxed mb-6">
          Facilitating church planting movements and disciple making movements since 1988.
        </p>
        <div class="flex gap-3">
          <a href="https://www.facebook.com/WorldMissionsandEvangelismInc" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 text-white/40 flex items-center justify-center hover:bg-gold-500 hover:text-white transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/world-missions-evangelism" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 text-white/40 flex items-center justify-center hover:bg-gold-500 hover:text-white transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="https://www.youtube.com/@WorldMissionsEvangel" target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-full bg-white/5 text-white/40 flex items-center justify-center hover:bg-gold-500 hover:text-white transition-all duration-300">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick links -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm">Quick Links</h4>
        <ul class="space-y-2.5">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-white/40 hover:text-gold-400 transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Regions -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm">Regions</h4>
        <ul class="space-y-2.5">
          {regions.map((link) => (
            <li>
              <a href={link.href} class="text-white/40 hover:text-gold-400 transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4 class="font-semibold text-white mb-4 text-sm">Resources</h4>
        <ul class="space-y-2.5">
          {resources.map((link) => (
            <li>
              <a href={link.href} class="text-white/40 hover:text-gold-400 transition-colors text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="py-6 border-t border-white/5 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        &copy; {currentYear} World Missions & Evangelism, Inc. All rights reserved.
      </p>
      <p class="text-white/20 text-xs">
        PO Box 790, Benton, KY 42025 &bull; (270) 527-9445
      </p>
    </div>
  </div>
</footer>
