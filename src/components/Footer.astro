---
const year = new Date().getFullYear();
---

<footer class="border-t border-white/[0.04] py-12">
  <div class="section-container">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <img src="/images/wme-logo.png" alt="W.M.E." class="h-8 brightness-0 invert opacity-50 mb-4" />
        <p class="text-slate-600 text-[13px] leading-relaxed">
          Facilitating church planting movements since 1988.
        </p>
      </div>

      <!-- Links -->
      {[
        { title: 'Ministry', links: [['About', '#about'], ['INSTAR', '#instar'], ['Team', '#team'], ['Events', '#events']] },
        { title: 'Regions', links: [['Latin America', '#regions'], ['Southeast Asia', '#regions'], ['Africa', '#regions'], ['Caribbean', '#regions']] },
        { title: 'Connect', links: [['Give', '#give'], ['Prayer', '#prayer'], ['Contact', '#contact'], ['Newsletter', '#']] },
      ].map(col => (
        <div>
          <h4 class="text-[11px] font-semibold uppercase tracking-[0.15em] text-slate-600 mb-4">{col.title}</h4>
          <ul class="space-y-2">
            {col.links.map(([label, href]) => (
              <li><a href={href} class="text-slate-500 text-sm hover:text-amber-400 transition-colors">{label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="pt-8 border-t border-white/[0.04] flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-slate-700 text-xs">&copy; {year} World Missions & Evangelism, Inc.</p>
      <p class="text-slate-700 text-xs">PO Box 790, Benton, KY 42025 &bull; (270) 527-9445</p>
    </div>
  </div>
</footer>
