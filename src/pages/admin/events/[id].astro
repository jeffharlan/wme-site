---
export const prerender = false;

import AdminLayout from '../../../components/admin/AdminLayout.astro';
import { db } from '../../../lib/db';
import { events, formFields } from '../../../lib/schema';
import { eq, asc } from 'drizzle-orm';

const { id } = Astro.params;
const event = (await db.select().from(events).where(eq(events.id, id!)).limit(1))[0];
if (!event) return Astro.redirect('/admin/events');

const fields = await db.select().from(formFields).where(eq(formFields.eventId, id!)).orderBy(asc(formFields.sortOrder));
const message = Astro.url.searchParams.get('msg');
---

<AdminLayout title={`Edit: ${event.title}`} activeNav="events">
  {message === 'saved' && (
    <div style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; color: #34d399; font-size: 0.8125rem;">Changes saved.</div>
  )}
  {message === 'field_added' && (
    <div style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; color: #34d399; font-size: 0.8125rem;">Field added.</div>
  )}
  {message === 'field_deleted' && (
    <div style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; color: #34d399; font-size: 0.8125rem;">Field deleted.</div>
  )}
  {message === 'reordered' && (
    <div style="background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.2); border-radius: 0.5rem; padding: 0.75rem 1rem; margin-bottom: 1.25rem; color: #34d399; font-size: 0.8125rem;">Field order updated.</div>
  )}

  <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
    <!-- Left: Event Details -->
    <div>
      <form method="POST" action={`/api/events/${id}`} class="admin-card">
        <h2 style="color: #111827; font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem;">Event Details</h2>
        <div style="margin-bottom: 1rem;">
          <label class="admin-label">Title</label>
          <input type="text" name="title" value={event.title} required class="admin-input" />
        </div>
        <div style="margin-bottom: 1rem;">
          <label class="admin-label">Description</label>
          <textarea name="description" rows="3" class="admin-input" style="resize: vertical;">{event.description}</textarea>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem;">
          <div>
            <label class="admin-label">Date</label>
            <input type="date" name="event_date" value={event.eventDate || ''} class="admin-input" />
          </div>
          <div>
            <label class="admin-label">Location</label>
            <input type="text" name="location" value={event.location || ''} class="admin-input" />
          </div>
        </div>
        <div style="margin-bottom: 1.25rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; color: #6b7280; font-size: 0.875rem; cursor: pointer;">
            <input type="checkbox" name="is_active" checked={event.isActive ? true : undefined} style="accent-color: #d4a017;" />
            Event is active (accepting registrations)
          </label>
        </div>
        <div style="display: flex; gap: 0.75rem; justify-content: space-between;">
          <button type="submit" class="admin-btn admin-btn-primary">Save Changes</button>
          <a href={`/admin/events/${id}/registrations`} class="admin-btn admin-btn-ghost">View Registrations →</a>
        </div>
      </form>

      <!-- Public link -->
      <div class="admin-card" style="margin-top: 1rem;">
        <h3 style="color: #6b7280; font-size: 0.6875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.12em; margin-bottom: 0.5rem;">Public Registration Link</h3>
        <div style="display: flex; align-items: center; justify-content: space-between;">
          <code style="color: #d4a017; font-size: 0.8125rem; word-break: break-all;">/events/{event.slug}</code>
          <a href={`/events/${event.slug}`} target="_blank" class="admin-btn admin-btn-ghost" style="font-size: 0.75rem; padding: 0.375rem 0.75rem;">Preview →</a>
        </div>
      </div>

      <!-- Danger zone -->
      <div class="admin-card" style="margin-top: 1rem; border-color: rgba(239,68,68,0.15);">
        <h3 style="color: #f87171; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 0.75rem;">Danger Zone</h3>
        <form method="POST" action={`/api/events/${id}?action=delete`} onsubmit="return confirm('Delete this event and all its registrations? This cannot be undone.')">
          <button type="submit" class="admin-btn admin-btn-danger" style="font-size: 0.8125rem;">Delete Event</button>
        </form>
      </div>
    </div>

    <!-- Right: Form Fields -->
    <div>
      <div class="admin-card">
        <h2 style="color: #111827; font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem;">Registration Form Fields</h2>

        {fields.length > 0 && (
          <div style="margin-bottom: 1.25rem;">
            {fields.map((field, i) => (
              <div style="display: flex; align-items: center; justify-content: space-between; padding: 0.625rem 0; border-bottom: 1px solid #f3f4f6;">
                <div style="display: flex; align-items: center; gap: 0.5rem;">
                  <div style="display: flex; flex-direction: column; gap: 2px;">
                    {i > 0 ? (
                      <form method="POST" action={`/api/fields/${field.id}?action=move_up&event_id=${id}`} style="margin: 0;">
                        <button type="submit" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 0.625rem; padding: 0; line-height: 1;" title="Move up">▲</button>
                      </form>
                    ) : <span style="font-size: 0.625rem; color: transparent;">▲</span>}
                    {i < fields.length - 1 ? (
                      <form method="POST" action={`/api/fields/${field.id}?action=move_down&event_id=${id}`} style="margin: 0;">
                        <button type="submit" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 0.625rem; padding: 0; line-height: 1;" title="Move down">▼</button>
                      </form>
                    ) : <span style="font-size: 0.625rem; color: transparent;">▼</span>}
                  </div>
                  <div>
                    <span style="color: #111827; font-size: 0.875rem; font-weight: 500;">{field.label}</span>
                    <span style="color: #9ca3af; font-size: 0.75rem; margin-left: 0.5rem;">{field.fieldType}</span>
                    {field.isRequired && <span style="color: #d4a017; font-size: 0.6875rem; margin-left: 0.5rem;">required</span>}
                  </div>
                </div>
                <form method="POST" action={`/api/fields/${field.id}?action=delete&event_id=${id}`} style="margin: 0;">
                  <button type="submit" style="background: none; border: none; color: #9ca3af; cursor: pointer; font-size: 0.75rem; padding: 0.25rem;" title="Delete field">✕</button>
                </form>
              </div>
            ))}
          </div>
        )}

        <form method="POST" action="/api/fields" style="border-top: 1px solid #e5e7eb; padding-top: 1.25rem;">
          <h3 style="color: #6b7280; font-size: 0.75rem; font-weight: 600; margin-bottom: 1rem;">Add New Field</h3>
          <input type="hidden" name="event_id" value={id} />
          <input type="hidden" name="sort_order" value={fields.length} />

          <div style="margin-bottom: 0.75rem;">
            <label class="admin-label">Field Label</label>
            <input type="text" name="label" required class="admin-input" placeholder="e.g. How many are attending?" />
          </div>
          <div style="display: grid; grid-template-columns: 1fr auto; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div>
              <label class="admin-label">Field Type</label>
              <select name="field_type" class="admin-input admin-select">
                <option value="text">Text</option>
                <option value="email">Email</option>
                <option value="tel">Phone</option>
                <option value="number">Number</option>
                <option value="textarea">Text Area</option>
                <option value="select">Dropdown</option>
              </select>
            </div>
            <div>
              <label class="admin-label">Required?</label>
              <label style="display: flex; align-items: center; gap: 0.5rem; color: #6b7280; font-size: 0.8125rem; padding-top: 0.5rem;">
                <input type="checkbox" name="is_required" checked style="accent-color: #d4a017;" />
                Yes
              </label>
            </div>
          </div>
          <div style="margin-bottom: 1rem;">
            <label class="admin-label">Options (for dropdown, comma-separated)</label>
            <input type="text" name="options" class="admin-input" placeholder="e.g. 1,2,3,4,5+" />
          </div>
          <button type="submit" class="admin-btn admin-btn-primary" style="width: 100%; justify-content: center;">Add Field</button>
        </form>
      </div>
    </div>
  </div>
</AdminLayout>
